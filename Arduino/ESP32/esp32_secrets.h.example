#pragma once

#define WIFI_SSID "CHANGE_ME"
#define WIFI_PASSWORD "CHANGE_ME"

#define MQTT_SERVER "broker.example.com"
#define MQTT_PORT_VALUE 8883
#define MQTT_USER "CHANGE_ME"
#define MQTT_PASSWORD "CHANGE_ME"

// Optional: per-board device/sensor codes.
// Keep defaults or override to support many ESP32 boards in one system.
// These values must match `device.code` created on the web/backend.
#define DEVICE_CODE_DEN "den"
#define DEVICE_CODE_QUAT "quat"

#define SENSOR_CODE_TEMPERATURE "temperature"
#define SENSOR_CODE_HUMIDITY "humidity"
#define SENSOR_CODE_LIGHT "light"
#define SENSOR_CODE_PIR "pir"

// Optional: MQTT v2 type names for scalable topics home/{category}/{type}/{device_id}
// Example actuator topics:
//   home/control/light/den1
//   home/status/fan/quat1
// Example sensor topics:
//   home/sensors/humidity/do_am_a1
//   home/sensors/motion/chuyen_dong_a1
#define DEVICE_TYPE_DEN "light"
#define DEVICE_TYPE_QUAT "fan"

#define SENSOR_TYPE_TEMPERATURE "temperature"
#define SENSOR_TYPE_HUMIDITY "humidity"
#define SENSOR_TYPE_LIGHT "light"
#define SENSOR_TYPE_PIR "motion"

// ⚠️  SECURITY: Only disable certificate verification for development/testing
// NEVER use MQTT_ALLOW_INSECURE_TLS=1 in production (allows MITM attacks)
#define MQTT_ALLOW_INSECURE_TLS 0

// ✅ RECOMMENDED: Always use CA certificate pinning for production
#define MQTT_USE_CA_CERT 1

static const char MQTT_ROOT_CA[] = R"EOF(
-----BEGIN CERTIFICATE-----
PASTE_CA_CERTIFICATE_HERE
-----END CERTIFICATE-----
)EOF";