# Frontend environment variables
# Copy to .env.local and fill in values — never commit .env.local

# Backend base URL for HTTP API calls and Socket.IO connection.
# In development (Vite proxy active), leave EMPTY so requests go through proxy.
# In production, set to your deployed backend: https://your-server.com
VITE_BASE_URL=

# Internal token must match INTERNAL_TOKEN in backend .env
VITE_INTERNAL_TOKEN=your_internal_token_here
