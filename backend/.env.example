# ============================================================
# .env.example  — copy to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# Application
FLASK_ENV=development          # change to "production" on server
FLASK_DEBUG=0

# Flask session & token signing (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=replace-with-a-strong-random-key

# Internal API <-> GUI token (generate the same way as SECRET_KEY)
INTERNAL_TOKEN=replace-with-a-strong-random-token

# Database
DB_USER=iot_user
DB_PASS=replace-with-secure-db-password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=batman_os

# Database root (only used by init_db.py setup script)
DB_ROOT_USER=root
DB_ROOT_PASS=replace-with-root-password

# MQTT broker
MQTT_URL=your-broker-host.example.com
MQTT_PORT=8883
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password
MQTT_USE_TLS=true

# Google Gemini AI
GEMINI_API_KEY=replace-with-your-gemini-api-key

# Socket.IO CORS — comma-separated list of allowed origins
SOCKETIO_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# CORS cho REST API — same list (thêm domain thật khi deploy)
# CORS_ORIGINS=https://your-frontend-domain.com,http://127.0.0.1:5173
