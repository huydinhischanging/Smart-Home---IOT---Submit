          <mxGeometry x="245" y="644" width="210" height="76" as="geometry" />
        </mxCell>
        <mxCell id="a_ctrl" value="Resolve rooms → filter devices&#xa;store_pending(kind=control)&#xa;Return confirmation prompt  (all modes)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="498" y="649" width="265" height="66" as="geometry" />
        </mxCell>

        <!-- Step 7: Small-talk -->
