          <mxGeometry x="245" y="558" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="a_info" value="Answer from live house context&#xa;No device command  (all modes)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="498" y="565" width="265" height="56" as="geometry" />
        </mxCell>

        <!-- Step 6: Device control -->
