          <mxGeometry x="245" y="736" width="210" height="72" as="geometry" />
        </mxCell>
        <mxCell id="a_c0" value="Return greeting / small-talk reply&#xa;(all modes)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="498" y="744" width="265" height="56" as="geometry" />
        </mxCell>

        <!-- Step 8: Mood + Scenario -->
        <mxCell id="d_c1" value="Step 8 — Mood / Scenario&#xa;MOOD_PROFILES keyword?&#xa;ALFRED_SCENARIOS keyword?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="245" y="824" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a_c1" value="store_pending (mood_only or scenario plan)&#xa;Return suggestion + confirmation prompt&#xa;(all modes)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="498" y="831" width="265" height="66" as="geometry" />
        </mxCell>

        <!-- Step 9: Fallback -->
        <mxCell id="a_d" value="Step 9 — Fallback&#xa;rule    →  not_understood_reply()&#xa;gemini  →  Gemini 2.5 Flash  (house-context prompt)&#xa;llm     →  Ollama parse_intent()  →  execute or reply" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="130" y="926" width="560" height="90" as="geometry" />
